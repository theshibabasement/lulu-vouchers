# ==============================================================
# Lulu Brechó · variáveis de ambiente
# ==============================================================

# ---- Autenticação (login simples por env) ----
AUTH_USER=lulu
AUTH_PASSWORD=trocar-essa-senha
# Mínimo 32 caracteres. Gere com: openssl rand -hex 32
AUTH_SECRET=sub_aleatorio_de_pelo_menos_32_chars_aqui_____

# ---- Postgres ----
POSTGRES_USER=lulu
POSTGRES_PASSWORD=senha_forte_do_banco
POSTGRES_DB=lulu_vales

# ---- App ----
# DATABASE_URL é montada automaticamente pelo docker-compose a partir das vars acima.
# Para rodar fora do compose, defina manualmente:
# DATABASE_URL=postgres://lulu:senha@localhost:5432/lulu_vales
# DATA_DIR=./data

# URL pública do portal — usada pra montar o QR code do recibo e o link
# que vai pelo WhatsApp. Em produção (Dokploy + Traefik) defina com o domínio
# configurado, ex.: https://vouchers-lulu.prod.lime.my.id
# Se omitido, o app deduz do header Host (funciona, mas pode pegar host
# interno em algumas configurações de proxy).
PORTAL_BASE_URL=
